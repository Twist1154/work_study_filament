<?php

declare(strict_types=1);

namespace App\Filament\Staff\Resources;

use App\Models\Registration;
use App\Models\Appointment;
use App\Models\StaffMember;
use Filament\Resources\Resource;
use Filament\Tables;
use Filament\Tables\Table;
use Filament\Tables\Actions\Action;
use Filament\Forms\Components\Toggle;
use Filament\Schemas\Schema;
use Filament\Infolists\Components\TextEntry;
use Filament\Infolists\Components\IconEntry;
use Filament\Infolists\Components\RepeatableEntry;
use Filament\Schemas\Components\Section;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Storage;
use App\Filament\Staff\Resources\RegistrationResource\Pages; // FIXED: Added correct Pages namespace [1.1.2]

class RegistrationResource extends Resource
{
    protected static ?string $model = Registration::class;

    protected static string|null|\BackedEnum $navigationIcon = 'heroicon-o-clipboard-document-check';

    protected static ?string $navigationLabel = 'Student Onboarding';

    protected static ?string $pluralModelLabel = 'Student Onboarding';

    public static function table(Table $table): Table
    {
        return $table
            ->query(
            // Auto-excludes approved registrations from the active queue to keep the list clean
                Registration::query()->whereNot('status', 'approved')
            )
            ->columns([
                Tables\Columns\TextColumn::make('student.student_number')
                    ->label('Student Number')
                    ->searchable()
                    ->sortable(),

                Tables\Columns\TextColumn::make('student.surname')
                    ->label('Surname')
                    ->searchable()
                    ->sortable(),

                Tables\Columns\TextColumn::make('student.first_names')
                    ->label('First Name(s)'),

                Tables\Columns\TextColumn::make('status')
                    ->badge()
                    ->color(fn (string $state): string => match ($state) {
                        'approved' => 'success',
                        'rejected' => 'danger',
                        'pending_hod_approval' => 'warning',
                        'pending_final' => 'info',
                        default => 'gray',
                    })
                    ->formatStateUsing(fn (string $state): string => str_replace('_', ' ', ucfirst($state))),
            ])
            ->actions([
                // 1. Opens the Schema-based detailed onboarding package viewer [1.1.2]
                Tables\Actions\ViewAction::make()
                    ->modalHeading('Review Student Onboarding Package')
                    ->modalWidth('5xl'),

                // 2. Action: Dean Assistant / Coordinator initial step verification [1.2.3]
                Action::make('verify')
                    ->label('Verify Package')
                    ->visible(fn ($record) => in_array($record->status, ['pending_student', 'pending_verification']))
                    ->form([
                        Section::make('Section-by-Section Verification')
                            ->description('Check off each step. If rejected, toggle off to record a comment.')
                            ->schema([
                                Toggle::make('biographical_approved')
                                    ->label('Biographical & Address Details Approved')
                                    ->default(true)
                                    ->live(),
                                Textarea::make('biographical_comments')
                                    ->label('Correction Reason')
                                    ->visible(fn (callable $get) => !$get('biographical_approved'))
                                    ->required(fn (callable $get) => !$get('biographical_approved')),

                                Toggle::make('banking_approved')
                                    ->label('Banking Details Approved')
                                    ->default(true)
                                    ->live(),
                                Textarea::make('banking_comments')
                                    ->label('Correction Reason')
                                    ->visible(fn (callable $get) => !$get('banking_approved'))
                                    ->required(fn (callable $get) => !$get('banking_approved')),

                                Toggle::make('documents_approved')
                                    ->label('Supporting Documents Approved')
                                    ->default(true)
                                    ->live(),
                                Textarea::make('documents_comments')
                                    ->label('Correction Reason')
                                    ->visible(fn (callable $get) => !$get('documents_approved'))
                                    ->required(fn (callable $get) => !$get('documents_approved')),
                            ])
                    ])
                    ->action(function ($record, array $data) {
                        $allApproved = $data['biographical_approved'] && $data['banking_approved'] && $data['documents_approved'];

                        $record->verification_status = [
                            'biographical' => [
                                'approved' => $data['biographical_approved'],
                                'comments' => $data['biographical_comments'] ?? null,
                            ],
                            'banking' => [
                                'approved' => $data['banking_approved'],
                                'comments' => $data['banking_comments'] ?? null,
                            ],
                            'documents' => [
                                'approved' => $data['documents_approved'],
                                'comments' => $data['documents_comments'] ?? null,
                            ],
                        ];

                        if ($allApproved) {
                            $record->status = 'pending_hod_approval';
                            Tables\Actions\Action::make('success')->success()->title('Verification Complete')->body('Forwarded to HOD sign-off.')->send();
                        } else {
                            $record->status = 'rejected';
                            Tables\Actions\Action::make('danger')->danger()->title('Onboarding Rejected')->body('Feedback sent to student.')->send();
                        }
                        $record->save();
                    })
                    ->color('warning'),

                // 3. Action: HOD countersigning [1.2.3]
                Action::make('hodSign')
                    ->label('HOD Sign-Off')
                    ->visible(fn ($record) => $record->status === 'pending_hod_approval')
                    ->form([
                        Toggle::make('agree_to_terms')
                            ->label('I countersign the Terms and Conditions and approve this department placement.')
                            ->required(),
                    ])
                    ->action(fn ($record) => $record->update(['status' => 'pending_final']))
                    ->color('success'),

                // 4. Action: Dean Assistant final check and automatic Appointment creation [1.2.3]
                Action::make('finalApprove')
                    ->label('Final Approve & Appoint')
                    ->visible(fn ($record) => $record->status === 'pending_final')
                    ->action(function ($record) {
                        DB::transaction(function () use ($record) {
                            // Approve registration status
                            $record->update(['status' => 'approved']);

                            // Auto-generate the active appointment [1.1.2]
                            Appointment::create([
                                'student_id' => $record->student_id,
                                'registration_id' => $record->registration_id,
                                'job_category_id' => 1, // Default fallback or mapped from invitation
                                'department_id' => 1,
                                'campus_id' => 1,
                                'supervisor_id' => 1,
                                'commencement_date' => now()->toDateString(),
                                'remuneration_rate_per_hour' => 50.00,
                                'appointment_type' => 'New Appointment',
                                'status' => 'active',
                            ]);
                        });

                        Tables\Actions\Action::make('success')->success()->title('Appointment Created')->body('Active appointment has been registered.')->send();
                    })
                    ->color('success'),
            ]);
    }

    public static function infolist(Schema $schema): Schema
    {
        return $schema
            ->components([
                Section::make('Student Biographical Information')
                    ->columns(3)
                    ->schema([
                        TextEntry::make('student.student_number')->label('Student Number'),
                        TextEntry::make('student.first_names')->label('First Name(s)'),
                        TextEntry::make('student.surname')->label('Surname'),
                        TextEntry::make('student.gender')->label('Gender'),
                        TextEntry::make('student.date_of_birth')->label('Date of Birth')->date(),
                        TextEntry::make('student.id_passport_number')->label('ID / Passport Number'),
                        TextEntry::make('student.sars_tax_number')->label('SARS Tax Number')->placeholder('None Provided'),
                        IconEntry::make('student.is_foreign_student')->label('Foreign Student?')->boolean(),
                        TextEntry::make('student.work_permit_number')
                            ->label('Work Permit Number')
                            ->placeholder('N/A'),
                        TextEntry::make('student.work_permit_expiry')
                            ->label('Work Permit Expiry')
                            ->date()
                            ->placeholder('N/A'),
                    ]),

                Section::make('Banking Details')
                    ->columns(3)
                    ->schema([
                        TextEntry::make('student.bankDetail.bank_name')->label('Bank'),
                        TextEntry::make('student.bankDetail.account_type')->label('Account Type'),
                        TextEntry::make('student.bankDetail.account_number')->label('Account Number'),
                        TextEntry::make('student.bankDetail.branch_name')->label('Branch Name')->placeholder('N/A'),
                        TextEntry::make('student.bankDetail.branch_code')->label('Branch Code')->placeholder('N/A'),
                        TextEntry::make('student.bankDetail.ownership_type')->label('Account Ownership'),
                    ]),

                Section::make('Uploaded Supporting Documents')
                    ->schema([
                        RepeatableEntry::make('student.documents')
                            ->label('Document Library')
                            ->schema([
                                TextEntry::make('document_type')->label('Document Type'),
                                TextEntry::make('file_path')
                                    ->label('Action')
                                    ->formatStateUsing(fn () => 'View / Download Attachment')
                                    ->url(fn ($record) => asset('storage/' . $record->file_path), shouldOpenInNewTab: true)
                                    ->color('primary'),
                                TextEntry::make('uploaded_at')->label('Uploaded At')->datetime(),
                            ])
                            ->columns(3)
                    ])
            ]);
    }

    public static function getPages(): array
    {
        return [
            'index' => Pages::ListRegistrations::route('/'),
        ];
    }
}
